// Schema bazy — aplikacja do zarządzania stowarzyszeniem.
// Multi-tenancy: dane każdego stowarzyszenia odizolowane przez organizationId.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Modele Auth.js (@auth/prisma-adapter) ──────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]

  // Domena: dostęp do stowarzyszeń wynika z dopasowania e-maila do wpisów Member.
  // Ostatnio wybrane (aktywne) stowarzyszenie użytkownika.
  activeOrganizationId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Domena: stowarzyszenia, członkostwo, role ──────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Dane rejestrowe stowarzyszenia (zaciągane z KRS przy zakładaniu) — wymagane.
  krs          String
  foundedYear  Int
  // Adres siedziby (rozbity) — wymagany.
  street       String
  postalCode   String
  city         String
  // NIP/REGON — opcjonalne (KRS nie zawsze je zwraca dla stowarzyszeń/fundacji).
  nip          String?
  regon        String?
  // Dane kontaktowe i opis — opcjonalne.
  contactEmail String?
  phone        String?
  description  String?
  // Logo stowarzyszenia jako data URL (image/png|jpeg) zapisane wprost w bazie —
  // renderuje się bezpośrednio w <img>, także na drukowanych dokumentach.
  logoUrl      String?

  // Link zapraszający — jeden na stowarzyszenie (regenerowalny, włącz/wyłącz).
  inviteToken   String? @unique // token w URL-u /join/<token>
  inviteEnabled Boolean @default(true)

  // Składki członkowskie.
  membershipPaid Boolean @default(false)
  // Roczny termin opłacenia składki — powtarzalny co roku dzień + miesiąc.
  // Na razie obsługujemy wyłącznie składki roczne.
  feeDueMonth    Int? // 1–12
  feeDueDay      Int? // 1–31 (zależnie od miesiąca)

  // Konfiguracja pól standardowych formularza zgłoszeniowego. Każde pole można
  // ukryć, uczynić nieobowiązkowym lub obowiązkowym. Data urodzenia domyślnie
  // wymagana (zgodnie z dotychczasowym zachowaniem), pozostałe domyślnie ukryte.
  formBirthDate FormFieldMode @default(REQUIRED)
  formPhone     FormFieldMode @default(HIDDEN)
  formAddress   FormFieldMode @default(HIDDEN)

  members           Member[]
  roles             Role[]
  applications      MembershipApplication[]
  applicationFields ApplicationField[]
  paymentTiers      PaymentTier[]
  membershipFees    MembershipFee[]
  meetings          Meeting[]
  resolutions       Resolution[]
}

// Rola w stowarzyszeniu (konfigurowalna) + macierz uprawnień (JSON: obszar → poziom).
model Role {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String

  name        String
  permissions Json // { MEMBERS:"WRITE", APPLICATIONS:"READ", MEETINGS:"NONE", RESOLUTIONS:"NONE", SETTINGS:"NONE" }
  isOwner     Boolean  @default(false) // pełne uprawnienia, zablokowana do edycji/usuwania
  isSystem    Boolean  @default(false) // Prezes/Członek — nieusuwalne
  isDefault   Boolean  @default(false) // rola nadawana zatwierdzonym zgłoszeniom (Członek)
  // Rola zwolniona z opłacania składek (np. Junior, Członek Honorowy) — członkowie z
  // taką rolą nie są obciążani składką ani liczeni do zaległości/opłacalności.
  feeExempt   Boolean  @default(false)
  // Czy rola ma prawo głosu (głosowania nad uchwałami i punktami porządku obrad).
  canVote     Boolean  @default(true)
  createdAt   DateTime @default(now())

  members      Member[]
  meetingRoles MeetingRole[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

// ─── Domena: członkowie stowarzyszenia i zgłoszenia ─────────────────────────

enum ApplicationStatus {
  PENDING // oczekuje na decyzję
  APPROVED // zatwierdzone
  REJECTED // odrzucone
}

enum FieldType {
  STRING // na razie tylko tekst; enum zostawia miejsce na kolejne typy
}

// Typ pola-linku formularza. Etykieta i szablon URL wynikają z typu — użytkownik
// podaje na formularzu wyłącznie identyfikator (resztę adresu dokładamy sami).
enum LinkType {
  FACEBOOK
  LINKEDIN
  EGD // European Go Database
}

// Tryb pola standardowego formularza zgłoszeniowego (data urodzenia, telefon, adres):
// ukryte na formularzu, opcjonalne (do wypełnienia) lub wymagane.
enum FormFieldMode {
  HIDDEN // nie pokazuj pola na formularzu
  OPTIONAL // pole nieobowiązkowe
  REQUIRED // pole obowiązkowe
}

enum PaymentStatus {
  NOT_REQUIRED // członkostwo bezpłatne
  PENDING // oczekuje na płatność
  PAID // opłacone
}

// Próg składki członkowskiej (konfiguracja). Kwota w groszach.
model PaymentTier {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String

  label     String
  amount    Int // grosze (np. 10000 = 100,00 zł)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  members Member[]

  @@index([organizationId])
}

// Definicja dodatkowego pola formularza zgłoszeniowego (konfigurowane przez admina).
model ApplicationField {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String

  label     String
  type      FieldType @default(STRING)
  // Gdy ustawione, pole jest „linkiem": etykieta i adres URL wynikają z typu,
  // a użytkownik podaje na formularzu wyłącznie identyfikator. null → pole tekstowe.
  linkType  LinkType?
  required  Boolean   @default(false)
  order     Int       @default(0) // kolejność na formularzu
  createdAt DateTime  @default(now())

  @@index([organizationId])
}

// Zgłoszenie z publicznego formularza (link zapraszający). Nie jest jeszcze członkiem.
model MembershipApplication {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String

  firstName String
  lastName  String
  email     String
  // Pola standardowe sterowane konfiguracją formularza (formBirthDate/Phone/Address) —
  // wszystkie opcjonalne na poziomie bazy; obowiązkowość wymusza walidacja zgłoszenia.
  birthDate DateTime?
  phone     String?
  address   String?

  // Odpowiedzi z pól własnych — migawka [{ label, value }] z chwili zgłoszenia.
  customData Json?

  // Płatność (migawka progu z chwili zgłoszenia + status ze Stripe).
  paymentStatus    PaymentStatus @default(NOT_REQUIRED)
  paymentTierLabel String?
  paymentAmount    Int? // grosze
  stripeSessionId  String?
  paymentUrl       String? // link do dokończenia płatności (Stripe Checkout)

  status       ApplicationStatus @default(PENDING)
  createdAt    DateTime          @default(now())
  reviewedAt   DateTime?
  reviewedById String? // userId administratora, który rozpatrzył (pole audytowe)

  @@index([organizationId, status])
}

// Członek stowarzyszenia (ewidencja). Dostęp do panelu = dopasowanie e-maila
// zalogowanego użytkownika do wpisu Member. Rola steruje uprawnieniami.
model Member {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String

  role   Role   @relation(fields: [roleId], references: [id])
  roleId String

  firstName String
  lastName  String? // opcjonalne (np. jednoczłonowa nazwa założyciela)
  email     String
  birthDate DateTime? // opcjonalne (założyciel nie wypełniał formularza)
  // Dane kontaktowe/adresowe przeniesione ze zgłoszenia (zależnie od konfiguracji
  // formularza). Opcjonalne — założyciel/import mogą ich nie mieć.
  phone     String?
  address   String?
  // Migawka pól własnych ze zgłoszenia ([{ label, value }]) przeniesiona przy
  // zatwierdzeniu — pełne dane członka w jednym miejscu.
  customData Json?
  joinedAt  DateTime  @default(now())

  // Przypisany próg składki (z konfiguracji stowarzyszenia). null = nieprzypisany.
  // Roczna kwota składki członka = paymentTier.amount.
  paymentTier   PaymentTier? @relation(fields: [paymentTierId], references: [id], onDelete: SetNull)
  paymentTierId String?

  attendances     MeetingAttendance[]
  agendaComments  AgendaComment[]
  agendaVotes     AgendaVote[]
  resolutionVotes      ResolutionVote[]
  resolutionSignatures ResolutionSignature[]
  membershipFees       MembershipFee[]

  @@unique([organizationId, email]) // jeden e-mail = jeden członek danego stowarzyszenia
  @@index([organizationId])
  @@index([roleId])
}

// Opłacenie rocznej składki przez członka. Istnienie rekordu = składka opłacona za
// dany rok rozliczeniowy; brak rekordu = nieopłacona (zaległa po terminie). Składki
// są roczne, więc klucz to (członek, rok). Kwota opcjonalna — na razie oznaczamy
// tylko fakt opłacenia.
model MembershipFee {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  member         Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId       String

  year   Int // rok rozliczeniowy
  amount Int? // grosze — kwota wpłaty (opcjonalnie, na przyszłość)
  paidAt DateTime @default(now())

  @@unique([memberId, year])
  @@index([organizationId, year])
}

// ─── Domena: spotkania (walne zebrania, posiedzenia zarządu) ─────────────────

enum MeetingType {
  GENERAL_ASSEMBLY // Walne zebranie
  BOARD_MEETING // Posiedzenie zarządu
}

// Spotkanie stowarzyszenia. Lista uprawnionych ról steruje tym, kto widzi je
// wśród „nadchodzących”. Brak ról (pusta lista) = otwarte dla wszystkich członków.
model Meeting {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String

  title    String
  type     MeetingType
  startsAt DateTime // data i godzina rozpoczęcia
  location String? // adres albo URL do spotkania online

  // Zakończenie spotkania. null = zaplanowane lub w toku (wg startsAt vs teraz).
  endedAt DateTime?

  // Role uprawnione do udziału. Pusta lista = wszyscy członkowie.
  allowedRoles MeetingRole[]
  agendaItems  AgendaItem[]
  attendances  MeetingAttendance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, startsAt])
}

// Łącznik wiele-do-wielu: które role mogą wziąć udział w danym spotkaniu.
model MeetingRole {
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId String
  role      Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId    String

  @@id([meetingId, roleId])
  @@index([roleId])
}

enum AgendaItemStatus {
  PENDING // do rozpatrzenia
  APPROVED // zatwierdzony przez zebranie
  REJECTED // odrzucony przez zebranie
}

// Punkt porządku obrad. Status zmieniany w widoku spotkania (zatwierdź/odrzuć).
model AgendaItem {
  id        String  @id @default(cuid())
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId String

  order       Int              @default(0)
  title       String
  description String?
  status      AgendaItemStatus @default(PENDING)
  votable     Boolean          @default(true) // czy punkt podlega głosowaniu

  comments AgendaComment[]
  votes    AgendaVote[]

  createdAt DateTime @default(now())

  @@index([meetingId])
}

// Komentarz członka do punktu porządku obrad.
model AgendaComment {
  id           String     @id @default(cuid())
  agendaItem   AgendaItem @relation(fields: [agendaItemId], references: [id], onDelete: Cascade)
  agendaItemId String
  author       Member     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId     String

  text      String
  createdAt DateTime @default(now())

  @@index([agendaItemId])
  @@index([authorId])
}

enum VoteChoice {
  FOR // za
  AGAINST // przeciw
  ABSTAIN // wstrzymuje się
}

// Głos członka nad punktem porządku obrad (jeden głos na członka i punkt).
model AgendaVote {
  id           String     @id @default(cuid())
  agendaItem   AgendaItem @relation(fields: [agendaItemId], references: [id], onDelete: Cascade)
  agendaItemId String
  member       Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId     String

  choice    VoteChoice
  createdAt DateTime   @default(now())

  @@unique([agendaItemId, memberId])
  @@index([agendaItemId])
  @@index([memberId])
}

// Obecność członka na spotkaniu. Brak wiersza = nieodnotowany (traktowany jako nieobecny).
model MeetingAttendance {
  id        String  @id @default(cuid())
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId String
  member    Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId  String

  present Boolean @default(true)

  @@unique([meetingId, memberId])
  @@index([meetingId])
}

// ─── Domena: uchwały (rejestr + głosowania online) ──────────────────────────

enum ResolutionStatus {
  DRAFT // Szkic — przygotowywana, brak głosowania
  VOTING // W głosowaniu — zbieranie głosów online
  PASSED // Przyjęta
  REJECTED // Odrzucona
}

// Rola (tytuł) podpisu pod uchwałą — każdy tytuł obsadzany jednokrotnie.
enum SignatureRole {
  CHAIRPERSON // Przewodniczący zebrania
  SECRETARY // Protokolant
}

// Uchwała stowarzyszenia. Wynik wyznaczany z głosów przy zamknięciu głosowania.
model Resolution {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String

  number  String // np. „5/2026" (unikalny w obrębie stowarzyszenia)
  title   String
  content String? // treść uchwały

  // Tryb głosowania: jawne (widać, kto jak głosował) lub tajne.
  secretBallot Boolean @default(false)

  status   ResolutionStatus @default(DRAFT)
  openedAt DateTime? // moment otwarcia głosowania
  decidedAt DateTime? // moment rozstrzygnięcia (przyjęcia/odrzucenia)

  votes      ResolutionVote[]
  signatures ResolutionSignature[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, number])
  @@index([organizationId])
}

// Podpis pod (zatwierdzoną) uchwałą. Reguły:
//  • jeden członek podpisuje daną uchwałę najwyżej raz (unikat resolutionId+memberId),
//  • każdy tytuł (Przewodniczący/Protokolant) obsadzany najwyżej raz (unikat resolutionId+role).
// signerName to migawka imienia i nazwiska z chwili podpisu (integralność dokumentu).
model ResolutionSignature {
  id           String     @id @default(cuid())
  resolution   Resolution @relation(fields: [resolutionId], references: [id], onDelete: Cascade)
  resolutionId String
  member       Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId     String

  role       SignatureRole
  signerName String
  signedAt   DateTime      @default(now())

  @@unique([resolutionId, memberId])
  @@unique([resolutionId, role])
  @@index([resolutionId])
}

// Głos członka nad uchwałą (jeden głos na członka i uchwałę).
model ResolutionVote {
  id           String     @id @default(cuid())
  resolution   Resolution @relation(fields: [resolutionId], references: [id], onDelete: Cascade)
  resolutionId String
  member       Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId     String

  choice    VoteChoice // FOR / AGAINST / ABSTAIN (wspólny enum z głosowaniem agendy)
  createdAt DateTime   @default(now())

  @@unique([resolutionId, memberId])
  @@index([resolutionId])
}

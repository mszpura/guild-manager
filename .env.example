# Skopiuj ten plik do `.env` i uzupełnij wartości. `.env` NIE trafia do repo.

# ─── Baza danych (PostgreSQL, np. Neon) ─────────────────────────────────────
# Neon: https://neon.tech → utwórz projekt → skopiuj "connection string".
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Auth.js ────────────────────────────────────────────────────────────────
# Wygeneruj sekret: `npx auth secret` (lub `openssl rand -base64 32`).
AUTH_SECRET="zmien-mnie"

# Google OAuth — https://console.cloud.google.com → APIs & Services → Credentials
# Redirect URI (dev): http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── E-mail (magic link) ────────────────────────────────────────────────────
# Dev: darmowe konto Mailtrap (https://mailtrap.io) lub Ethereal.
# Format: smtp://user:pass@host:port
EMAIL_SERVER="smtp://user:pass@sandbox.smtp.mailtrap.io:587"
EMAIL_FROM="Stowarzyszenie <no-reply@example.com>"
